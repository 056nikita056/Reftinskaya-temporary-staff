generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Factory {
  id             String          @id @default(uuid()) @db.Uuid
  name           String          @db.VarChar(255)
  timezone       String          @default("Asia/Yekaterinburg") @db.VarChar(64)
  theme          Json?
  active         Boolean         @default(true)
  outsourcers    Outsourcer[]
  usersFactories UsersFactory[]
  territories    TerritoryTree[]
  plans          Plan[]
  dormitories    Dormitory[]
  auditLogs      AuditLog[]
  compatRecords  CompatRecord[]

  @@map("factories")
}

model Outsourcer {
  id             String         @id @default(uuid()) @db.Uuid
  factoryId      String         @map("factory_id") @db.Uuid
  name           String         @db.VarChar(255)
  externalRef    String?        @map("external_ref") @db.VarChar(128)
  active         Boolean        @default(true)
  factory        Factory        @relation(fields: [factoryId], references: [id], onDelete: Restrict)
  usersFactories UsersFactory[]

  @@unique([factoryId, name])
  @@index([factoryId])
  @@map("outsourcers")
}

model Role {
  id         String      @id @default(uuid()) @db.Uuid
  code       String      @unique @db.VarChar(64)
  name       String      @db.VarChar(255)
  active     Boolean     @default(true)
  usersRoles UsersRole[]

  @@map("roles")
}

model User {
  id                  String               @id @default(uuid()) @db.Uuid
  login               String               @unique @db.VarChar(64)
  passwordHash        String?              @map("password_hash")
  mustChangePassword  Boolean              @default(false) @map("must_change_password")
  failedAttempts      Int                  @default(0) @map("failed_attempts")
  lockedUntil         DateTime?            @map("locked_until") @db.Timestamptz(6)
  active              Boolean              @default(true)
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  profile             UserProfile?
  usersFactories      UsersFactory[]
  usersRoles          UsersRole[]
  createdPlans        Plan[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  auditLogs           AuditLog[]

  @@map("users")
}

model Plan {
  id              String          @id @default(uuid()) @db.Uuid
  factoryId       String          @map("factory_id") @db.Uuid
  createdAt       DateTime        @default(now()) @map("created_at") @db.Date
  createdByUserId String          @map("created_by_user_id") @db.Uuid
  startDate       DateTime        @map("start_date") @db.Date
  endDate         DateTime        @map("end_date") @db.Date
  statusId        String          @default("00000000-0000-0000-0000-000000000001") @map("status_id") @db.Uuid
  factory         Factory         @relation(fields: [factoryId], references: [id], onDelete: Restrict)
  createdByUser   User            @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  status          PlanStatus      @relation(fields: [statusId], references: [id], onDelete: Restrict)
  operations      PlanOperation[]

  @@index([factoryId, startDate, endDate])
  @@index([createdByUserId])
  @@index([statusId])
  @@map("plans")
}

model PlanOperation {
  id               String        @id @default(uuid()) @db.Uuid
  planId           String        @map("plan_id") @db.Uuid
  territoryId      String        @map("territories_id") @db.Uuid
  operationId      String        @map("operation_id") @db.Uuid
  requiredCount    Int           @map("required_count")
  staffCount       Int?          @map("staff_count")
  outsourcingCount Int?          @map("outsourcing_count")
  hourlyPay        Decimal?      @map("hourly_pay") @db.Decimal(12, 2)
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  plan             Plan          @relation(fields: [planId], references: [id], onDelete: Cascade)
  territory        TerritoryTree @relation(fields: [territoryId], references: [id], onDelete: Restrict)
  operation        Operation     @relation(fields: [operationId], references: [id], onDelete: Restrict)

  @@index([planId, createdAt])
  @@index([territoryId])
  @@index([operationId])
  @@map("plan_operations")
}

model PlanStatus {
  id     String  @id @default(uuid()) @db.Uuid
  code   String  @unique @db.VarChar(64)
  title  String  @db.VarChar(160)
  active Boolean @default(true)
  plans  Plan[]

  @@map("plan_statuses")
}

model PriceList {
  id          String        @id @default(uuid()) @db.Uuid
  operationId String        @map("operation_id") @db.Uuid
  sectionId   String        @map("section_id") @db.Uuid
  cost        Float
  dateApplied DateTime?     @map("date_applyed") @db.Date
  operation   Operation     @relation(fields: [operationId], references: [id], onDelete: Restrict)
  section     TerritoryTree @relation(fields: [sectionId], references: [id], onDelete: Restrict)

  @@index([operationId])
  @@index([sectionId])
  @@index([dateApplied])
  @@map("price_list")
}

model TerritoryTree {
  id             String          @id @default(uuid()) @db.Uuid
  factoryId      String          @map("factory_id") @db.Uuid
  name           String
  parentId       String?         @map("parent_id") @db.Uuid
  isFolder       Boolean?        @map("is_folder")
  active         Boolean         @default(true)
  factory        Factory         @relation(fields: [factoryId], references: [id], onDelete: Restrict)
  parent         TerritoryTree?  @relation("TerritoryTreeChildren", fields: [parentId], references: [id], onDelete: Restrict)
  children       TerritoryTree[] @relation("TerritoryTreeChildren")
  planOperations PlanOperation[]
  prices         PriceList[]
  operations     Operation[]

  @@index([factoryId])
  @@index([factoryId, parentId])
  @@index([parentId])
  @@map("territories_tree")
}

model Operation {
  id             String          @id @default(uuid()) @db.Uuid
  parentId       String?         @map("parent_id") @db.Uuid
  sectionId      String?         @map("section_id") @db.Uuid
  name           String          @db.VarChar(255)
  isFolder       Boolean         @default(false) @map("is_folder")
  active         Boolean         @default(true)
  parent         Operation?      @relation("OperationChildren", fields: [parentId], references: [id], onDelete: Restrict)
  children       Operation[]     @relation("OperationChildren")
  section        TerritoryTree?  @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  planOperations PlanOperation[]
  prices         PriceList[]

  @@index([parentId])
  @@index([sectionId])
  @@map("operations")
}

model Dormitory {
  id               String           @id @default(uuid()) @db.Uuid
  factoryId        String           @map("factory_id") @db.Uuid
  name             String           @db.VarChar(255)
  address          String
  active           Boolean          @default(true)
  factory          Factory          @relation(fields: [factoryId], references: [id], onDelete: Restrict)
  roomsDormitories RoomsDormitory[]

  @@index([factoryId])
  @@map("dormitories")
}

model RoomsDormitory {
  id          String    @id @default(uuid()) @db.Uuid
  dormitoryId String    @map("dormitories_id") @db.Uuid
  roomId      String    @map("rooms_id") @db.Uuid
  dormitory   Dormitory @relation(fields: [dormitoryId], references: [id], onDelete: Cascade)
  room        Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([dormitoryId, roomId])
  @@index([roomId])
  @@map("rooms_dormitories")
}

model Room {
  id               String           @id @default(uuid()) @db.Uuid
  roomNumber       String           @map("room_number") @db.VarChar(50)
  active           Boolean          @default(true)
  roomsDormitories RoomsDormitory[]
  roomPrices       RoomPriceList[]
  beds             Bed[]

  @@map("rooms")
}

model RoomPriceList {
  id          String    @id @default(uuid()) @db.Uuid
  roomId      String    @map("room_id") @db.Uuid
  cost        Decimal?  @db.Decimal(12, 2)
  dateApplied DateTime? @map("date_applyed") @db.Date
  room        Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([dateApplied])
  @@map("room_price_list")
}

model Bed {
  id                  String               @id @default(uuid()) @db.Uuid
  roomId              String               @map("room_id") @db.Uuid
  bedNumber           Int?                 @map("bed_number")
  active              Boolean              @default(true)
  room                Room                 @relation(fields: [roomId], references: [id], onDelete: Cascade)
  housingReservations HousingReservation[]
  housingFacts        HousingFact[]

  @@index([roomId])
  @@map("beds")
}

model HousingReservation {
  id                  String                    @id @default(uuid()) @db.Uuid
  employeeId          String                    @map("employee_id") @db.Uuid
  bedId               String                    @map("bed_id") @db.Uuid
  statusId            String?                   @map("status_id") @db.Uuid
  plannedCheckInDate  DateTime                  @map("planned_check_in_date") @db.Date
  plannedCheckOutDate DateTime                  @map("planned_check_out_date") @db.Date
  employee            Employee                  @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  bed                 Bed                       @relation(fields: [bedId], references: [id], onDelete: Restrict)
  status              HousingReservationStatus? @relation(fields: [statusId], references: [id], onDelete: Restrict)
  housingFacts        HousingFact[]

  @@index([employeeId])
  @@index([bedId])
  @@index([statusId])
  @@index([plannedCheckInDate, plannedCheckOutDate])
  @@map("housing_reservations")
}

model HousingReservationStatus {
  id           String               @id @default(uuid()) @db.Uuid
  title        String               @db.VarChar(160)
  isFinal      Boolean?             @map("is_final")
  active       Boolean              @default(true)
  reservations HousingReservation[]

  @@map("housing_reservation_statuses")
}

model HousingFact {
  id                   String              @id @default(uuid()) @db.Uuid
  employeeId           String?             @map("employee_id") @db.Uuid
  bedId                String?             @map("bed_id") @db.Uuid
  actualCheckInDate    DateTime?           @map("actual_check_in_date") @db.Date
  actualCheckOutDate   DateTime?           @map("actual_check_out_date") @db.Date
  statusId             String?             @map("status_id") @db.Uuid
  housingReservationId String?             @map("housing_reservation_id") @db.Uuid
  employee             Employee?           @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  bed                  Bed?                @relation(fields: [bedId], references: [id], onDelete: SetNull)
  status               HousingFactStatus?  @relation(fields: [statusId], references: [id], onDelete: Restrict)
  housingReservation   HousingReservation? @relation(fields: [housingReservationId], references: [id], onDelete: SetNull)

  @@index([employeeId])
  @@index([bedId])
  @@index([statusId])
  @@index([housingReservationId])
  @@map("housing_fact")
}

model HousingFactStatus {
  id      String        @id @default(uuid()) @db.Uuid
  title   String        @db.VarChar(160)
  isFinal Boolean?      @map("is_final")
  active  Boolean       @default(true)
  facts   HousingFact[]

  @@map("housing_fact_statuses")
}

model Employee {
  id                  String               @id @default(uuid()) @db.Uuid
  fullName            String               @map("full_name") @db.VarChar(255)
  country             String?              @db.VarChar(120)
  age                 Int?
  employeeStatusId    String?              @map("employee_statuses_id") @db.Uuid
  phone               String?              @db.VarChar(32)
  email               String?              @db.VarChar(255)
  birthDate           DateTime?            @map("birth_date") @db.Date
  passportNo          String?              @map("passport_no") @db.VarChar(120)
  passportIssued      String?              @map("passport_issued")
  registration        String?
  needsHousing        Boolean              @default(false) @map("needs_housing")
  needsRegistration   Boolean              @default(false) @map("needs_registration")
  driverCategories    String?              @map("driver_categories") @db.VarChar(160)
  status              EmployeeStatus?      @relation(fields: [employeeStatusId], references: [id], onDelete: Restrict)
  housingReservations HousingReservation[]
  housingFacts        HousingFact[]

  @@index([employeeStatusId])
  @@map("employees")
}

model EmployeeStatus {
  id        String     @id @default(uuid()) @db.Uuid
  title     String     @db.VarChar(160)
  active    Boolean    @default(true)
  employees Employee[]

  @@map("employee_statuses")
}

model UserProfile {
  userId    String   @id @map("user_id") @db.Uuid
  fullName  String   @map("full_name") @db.VarChar(255)
  phone     String?  @db.VarChar(32)
  email     String?  @db.VarChar(255)
  position  String?  @db.VarChar(160)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model UsersFactory {
  userId       String      @map("user_id") @db.Uuid
  factoryId    String      @map("factory_id") @db.Uuid
  outsourcerId String?     @map("outsourcer_id") @db.Uuid
  active       Boolean     @default(true)
  isPrimary    Boolean     @default(false) @map("is_primary")
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  factory      Factory     @relation(fields: [factoryId], references: [id], onDelete: Restrict)
  outsourcer   Outsourcer? @relation(fields: [outsourcerId], references: [id], onDelete: Restrict)

  @@id([userId, factoryId])
  @@index([factoryId])
  @@index([outsourcerId])
  @@map("users_factories")
}

model UsersRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("users_roles")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  jti       String    @unique @db.Uuid
  familyId  String    @map("family_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt, expiresAt])
  @@index([familyId, revokedAt, expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  factoryId String?  @map("factory_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String   @db.VarChar(64)
  entity    String?  @db.VarChar(64)
  entityId  String?  @map("entity_id") @db.Uuid
  details   Json?
  ip        String?  @db.VarChar(64)
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  factory   Factory? @relation(fields: [factoryId], references: [id], onDelete: SetNull)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([factoryId, createdAt])
  @@index([userId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}

model CompatRecord {
  id        String   @id @default(uuid()) @db.Uuid
  factoryId String   @map("factory_id") @db.Uuid
  resource  String   @db.VarChar(64)
  recordId  String   @map("record_id") @db.VarChar(128)
  data      Json
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  factory   Factory  @relation(fields: [factoryId], references: [id], onDelete: Cascade)

  @@unique([factoryId, resource, recordId])
  @@index([factoryId, resource])
  @@map("compat_records")
}
